{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Groundwater Streamlit App",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "app.py"],
      "cwd": "${workspaceFolder}/my_project",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "STREAMLIT_BROWSER_GATHER_USAGE_STATS": "false"
      }
    }
  ]
}
